{
    "$schema": "./node_modules/wrangler/config-schema.json",
    "name": "lena-student-web",
    "main": "./workers/app.ts",
    "compatibility_date": "2025-04-01",
    "compatibility_flags": [
        "nodejs_compat"
    ],
    "observability": {
        "enabled": true
    },
    "upload_source_maps": true,
    "vars": {
        "VALUE_FROM_CLOUDFLARE": "Hello from Cloudflare",
        "API_BASE_URL": "https://test.lena.africa"
    },
    "routes": [
        {
            "pattern": "student.lena.africa",
            "custom_domain": true
        }
    ]
}